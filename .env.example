# Copy to .env.local during implementation.
# Do not commit real secrets.

# Public app URL used in generated links and reports.
# In production, set this to the deployed app origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional AI summary provider key.
OPENAI_API_KEY=

# Optional persistence layer.
DATABASE_URL=

